{
  "name": "@godtbrod/domeneshop-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "description": "Domeneshop MCP for GB Studio — Entra-authenticated (user identity, group-gated), Domeneshop key held server-side, DNS pointer management with an audit trail.",
  "bin": { "domeneshop-mcp": "dist/index.js" },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "engines": { "node": ">=20" },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.34.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.1.0",
    "jose": "^6.2.3",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
