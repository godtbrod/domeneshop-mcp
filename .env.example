# --- Entra (identity) ---
ENTRA_TENANT_ID=ab29b1d2-828b-4eef-a756-293b13fcf4b5
# Token audience = the "GB Studio MCP" app id URI (and/or bare appId)
ENTRA_AUDIENCE=api://243c5378-8e17-4f9c-8351-c9e5454e73f8
# Callers must be a member of this Entra group (GB Studio Builders)
REQUIRED_GROUP_ID=659888ab-5511-4ab1-bd5e-8defe02a5c89
# ENTRA_ISSUER defaults to https://login.microsoftonline.com/<tenant>/v2.0

# --- Domeneshop credential (SERVER-SIDE ONLY — never handed to users) ---
# The Domeneshop API "token" (username) + "secret" (password) from
# https://domene.shop/admin?view=api. In the cluster these come from Key Vault
# via an ExternalSecret — NOT committed, NOT pasted into chat.
DOMENESHOP_TOKEN=
DOMENESHOP_SECRET=

# --- Guardrails ---
# Comma-separated apex domains that may be MUTATED. Empty = all mutations denied (reads still work).
DOMAIN_ALLOWLIST=godtbrod.no

# --- Server ---
PORT=3900
BIND=0.0.0.0
# Public base URL (for the OAuth resource-metadata document), e.g. https://domeneshop-mcp.gb.logiskbrist.no
PUBLIC_URL=
